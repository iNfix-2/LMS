# Paystack Payment Gateway Config
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYMENT_CURRENCY=NGN
SITE_URL=http://127.0.0.1:8000

# Email Config
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Edukom Learning <no-reply@edukomlearning.com>
ADMIN_NOTIFICATION_EMAIL=

# OpenAI AI Tools Configurations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest
AI_FEATURES_ENABLED=True
AI_DAILY_STUDENT_LIMIT=30
AI_DAILY_TUTOR_LIMIT=100
AI_REQUIRE_MODERATION=True
